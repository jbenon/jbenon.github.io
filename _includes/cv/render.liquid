<style>
  /* ── RenderCV-inspired styles, using al-folio theme variables ──────── */
  /* Prefix .rcv-wrap on all rules to beat al-folio's broad div/span/p selectors */

  .rcv-wrap { font-family: "Source Sans 3", "Source Sans Pro", sans-serif; }

  /* Header */
  .rcv-wrap .rcv-header { text-align: center; margin-bottom: 1.4rem; }
  .rcv-wrap .rcv-name {
    font-size: 2rem; font-weight: 700; font-variant: small-caps; letter-spacing: 0.04em;
    color: var(--global-theme-color) !important; margin: 0 0 0.25rem;
  }
  .rcv-wrap .rcv-headline {
    font-size: 1.1rem; font-weight: 700;
    color: var(--global-theme-color) !important; margin: 0 0 0.5rem;
  }
  .rcv-wrap .rcv-connections {
    display: flex; justify-content: center; flex-wrap: wrap; gap: 0 1rem; font-size: 0.92rem;
  }
  .rcv-wrap .rcv-connections a { color: var(--global-theme-color) !important; text-decoration: none; }
  .rcv-wrap .rcv-connections a:hover { color: var(--global-hover-color) !important; text-decoration: underline; }
  .rcv-wrap .rcv-connections .rcv-sep { color: var(--global-text-color-light) !important; }

  /* Section titles */
  .rcv-wrap .rcv-section { margin-top: 1.1rem; }
  .rcv-wrap .rcv-section-title {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: 1rem; font-weight: 700; font-variant: small-caps; letter-spacing: 0.05em;
    color: var(--global-theme-color) !important; margin-bottom: 0.45rem;
  }
  .rcv-wrap .rcv-section-title b { text-transform: uppercase; color: var(--global-theme-color) !important; font-weight: inherit; }
  .rcv-wrap .rcv-section-title::after {
    content: ""; flex: 1; height: 0.5pt; background: var(--global-theme-color); opacity: 0.55;
  }

  /* Entries */
  .rcv-wrap .rcv-entry { display: flex; gap: 0.6rem; margin-bottom: 0.55rem; align-items: baseline; }
  .rcv-wrap .rcv-entry:last-child { margin-bottom: 0; }
  .rcv-wrap .rcv-entry-main { flex: 1; font-size: 0.92rem; line-height: 1.45; }
  .rcv-wrap .rcv-entry-main p { margin: 0; }
  .rcv-wrap .rcv-entry-date {
    width: 7rem; min-width: 7rem; text-align: right; font-size: 0.92rem;
    color: var(--global-text-color-light) !important; white-space: nowrap; padding-top: 0.05rem;
  }

  /* Links in entries */
  .rcv-wrap .rcv-entry-main a { color: var(--global-theme-color) !important; text-decoration: none; }
  .rcv-wrap .rcv-entry-main a:hover { color: var(--global-hover-color) !important; text-decoration: underline; }

  /* Highlights */
  .rcv-wrap .rcv-highlights { margin: 0.15rem 0 0 0.5rem; padding-left: 0.9rem; font-size: 0.92rem; }
  .rcv-wrap .rcv-highlights li { margin-bottom: 0; line-height: 1.4; }

  /* Plain-text sections */
  .rcv-wrap .rcv-plain { font-size: 0.92rem; line-height: 1.5; }

  /* Strip jekyll-scholar's wrapping ol from the publications list */
  .rcv-wrap .bibliography { list-style: none; padding: 0; margin: 0; }
  .rcv-wrap .bibliography li { padding: 0; margin: 0 0 0.55em 0; }
  .rcv-wrap .bibliography li:last-child { margin-bottom: 0; }
</style>

<div class="post">
  {% if page.cv_pdf %}
  <div style="text-align: right; margin-bottom: 0.5rem;">
    <a
      {% if page.cv_pdf contains '://' %}
        href="{{ page.cv_pdf }}"
      {% else %}
        href="{{ page.cv_pdf | relative_url }}"
      {% endif %}
      target="_blank" rel="noopener noreferrer"
    ><i class="fa-solid fa-file-pdf"></i></a>
  </div>
  {% endif %}

  <article>
    <div class="rcv-wrap">
      {% assign cv = site.data.cv.cv %}

      <!-- ── Header ───────────────────────────────────────────────── -->
      {% if cv.name or cv.headline or cv.email or cv.phone or cv.website %}
        <div class="rcv-header">
          {% if cv.name %}
            <div class="rcv-name">{{ cv.name }}</div>
          {% endif %}
          {% if cv.headline %}
            <div class="rcv-headline">{{ cv.headline }}</div>
          {% endif %}
          <div class="rcv-connections">
            {% if cv.website %}
              <a href="{{ cv.website }}" target="_blank" rel="noopener noreferrer">
                <i class="fa-solid fa-link"></i> {{ cv.website | remove: 'https://' | remove: 'http://' }}
              </a>
            {% endif %}
            {% if cv.email %}
              <a href="mailto:{{ cv.email }}">
                <i class="fa-regular fa-envelope"></i> {{ cv.email }}
              </a>
            {% endif %}
            {% if cv.phone %}
              <span><i class="fa-solid fa-phone"></i> {{ cv.phone }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <!-- ── Sections ─────────────────────────────────────────────── -->
      {% for section_pair in cv.sections %}
        {% assign section_title = section_pair[0] %}
        {% assign section_entries = section_pair[1] %}

        <div class="rcv-section">
          <h3 id="{{ section_title | slugify }}" style="position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap;">{{ section_title }}</h3>
          <div class="rcv-section-title"><b>{{ section_title }}</b></div>

          <!-- Publications & Preprints -->
          {% if section_title contains "Publications" %}
              {% bibliography --template cv_bib --group_by none --sort_by year --order descending %}

          <!-- Classical RenderCV entries -->
          {% else %}
            {% for entry in section_entries %}

              <!-- "Education" entry -->
              {% if entry.institution and entry.area %}
                <div class="rcv-entry">
                  <div class="rcv-entry-main">
                    {% if entry.degree and entry.area and entry.institution %}
                      <strong>{{ entry.degree }} in {{ entry.area }}</strong> – <em>{{ entry.institution }}</em>
                    {% else %}
                      <strong>{{ entry.area }}</strong> – <em>{{ entry.institution }}</em>
                    {% endif %}
                    {% if entry.summary %}
                      <div>{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
                    {% endif %}
                    {% if entry.highlights %}
                      <ul class="rcv-highlights">
                        {% for h in entry.highlights %}
                          <li>{{ h | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>
                  <div class="rcv-entry-date">
                    {% if entry.start_date %}
                      {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                    {% elsif entry.end_date %}
                      {{ entry.end_date }}
                    {% elsif entry.date %}
                      {{ entry.date }}
                    {% endif %}
                  </div>
                </div>

              <!-- "Experience" entry -->
              {% elsif entry.company and entry.position %}
                <div class="rcv-entry">
                  <div class="rcv-entry-main">
                    <strong>{{ entry.position }}</strong> – <em>{{ entry.company }}</em>
                    {% if entry.summary %}
                      <div>{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
                    {% endif %}
                    {% if entry.highlights %}
                      <ul class="rcv-highlights">
                        {% for h in entry.highlights %}
                          <li>{{ h | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </div>
                  <div class="rcv-entry-date">
                    {% if entry.start_date %}
                      {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                    {% elsif entry.end_date %}
                      {{ entry.end_date }}
                    {% elsif entry.date %}
                      {{ entry.date }}
                    {% endif %}
                  </div>
                </div>

              <!-- "Normal" entry -->
              {% elsif entry.name %}
                <div class="rcv-entry">
                  <div class="rcv-entry-main">
                    {% if entry.name %}<strong>{{ entry.name }}</strong>{% endif %}
                    {% if entry.summary %}
                      <div style="font-size:0.9rem">
                        {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="rcv-entry-date">
                    {% if entry.start_date %}
                      {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                    {% elsif entry.end_date %}
                      {{ entry.end_date }}
                    {% elsif entry.date %}
                      {{ entry.date }}
                    {% endif %}
                  </div>
                </div>
              
                <!-- "Text" entry -->
                {% else %}
                  <div class="rcv-entry">
                    <div class="rcv-entry-main">
                      {{ entry }}
                    </div>
                  </div>

                {% endif %}
                  
            {% endfor %}
          {% endif %}
        
        </div><!-- /rcv-section -->
      {% endfor %}

    </div><!-- /rcv-wrap -->
  </article>
</div>
