<style>
  /* ── RenderCV-inspired styles, using al-folio theme variables ──────── */
  /* Prefix .rcv-wrap on all rules to beat al-folio's broad div/span/p selectors */

  .rcv-wrap { font-family: "Source Sans 3", "Source Sans Pro", sans-serif; }

  /* Header */
  .rcv-wrap .rcv-header { text-align: center; margin-bottom: 1.4rem; }
  .rcv-wrap .rcv-name {
    font-size: 2rem; font-weight: 700; font-variant: small-caps; letter-spacing: 0.04em;
    color: var(--global-theme-color) !important; margin: 0 0 0.25rem;
  }
  .rcv-wrap .rcv-headline {
    font-size: 1.1rem; font-weight: 700;
    color: var(--global-theme-color) !important; margin: 0 0 0.5rem;
  }
  .rcv-wrap .rcv-connections {
    display: flex; justify-content: center; flex-wrap: wrap; gap: 0 1rem; font-size: 0.92rem;
  }
  .rcv-wrap .rcv-connections a { color: var(--global-theme-color) !important; text-decoration: none; }
  .rcv-wrap .rcv-connections a:hover { color: var(--global-hover-color) !important; text-decoration: underline; }
  .rcv-wrap .rcv-connections .rcv-sep { color: var(--global-text-color-light) !important; }

  /* Section titles */
  .rcv-wrap .rcv-section { margin-top: 1.1rem; }
  .rcv-wrap .rcv-section-title {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: 1rem; font-weight: 700; font-variant: small-caps; letter-spacing: 0.05em;
    color: var(--global-theme-color) !important; margin-bottom: 0.45rem;
  }
  .rcv-wrap .rcv-section-title b { text-transform: uppercase; color: var(--global-theme-color) !important; font-weight: inherit; }
  .rcv-wrap .rcv-section-title::after {
    content: ""; flex: 1; height: 0.5pt; background: var(--global-theme-color); opacity: 0.55;
  }

  /* Entries */
  .rcv-wrap .rcv-entry { display: flex; gap: 0.6rem; margin-bottom: 0.55rem; align-items: baseline; }
  .rcv-wrap .rcv-entry:last-child { margin-bottom: 0; }
  .rcv-wrap .rcv-entry-main { flex: 1; font-size: 0.92rem; line-height: 1.45; }
  .rcv-wrap .rcv-entry-main p { margin: 0; }
  .rcv-wrap .rcv-entry-date {
    width: 7rem; min-width: 7rem; text-align: right; font-size: 0.83rem;
    color: var(--global-text-color-light) !important; white-space: nowrap; padding-top: 0.05rem;
  }

  /* Links in entries */
  .rcv-wrap .rcv-entry-main a { color: var(--global-theme-color) !important; text-decoration: none; }
  .rcv-wrap .rcv-entry-main a:hover { color: var(--global-hover-color) !important; text-decoration: underline; }

  /* Highlights */
  .rcv-wrap .rcv-highlights { margin: 0.15rem 0 0 0.5rem; padding-left: 0.9rem; font-size: 0.9rem; }
  .rcv-wrap .rcv-highlights li { margin-bottom: 0; line-height: 1.4; }

  /* Plain-text sections */
  .rcv-wrap .rcv-plain { font-size: 0.92rem; line-height: 1.5; }
</style>

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="rcv-wrap">
      {% assign cv = site.data.cv.cv %}

      <!-- ── Header ───────────────────────────────────────────────── -->
      {% if cv.name or cv.headline or cv.email or cv.phone or cv.website %}
        <div class="rcv-header">
          {% if cv.name %}
            <div class="rcv-name">{{ cv.name }}</div>
          {% endif %}
          {% if cv.headline %}
            <div class="rcv-headline">{{ cv.headline }}</div>
          {% endif %}
          <div class="rcv-connections">
            {% if cv.email %}
              <a href="mailto:{{ cv.email }}">
                <i class="fa-solid fa-envelope"></i> {{ cv.email }}
              </a>
            {% endif %}
            {% if cv.phone %}
              <span class="rcv-sep">|</span>
              <span><i class="fa-solid fa-phone"></i> {{ cv.phone }}</span>
            {% endif %}
            {% if cv.website %}
              <span class="rcv-sep">|</span>
              <a href="{{ cv.website }}" target="_blank" rel="noopener noreferrer">
                <i class="fa-solid fa-globe"></i> {{ cv.website | remove: 'https://' | remove: 'http://' }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <!-- ── Sections ─────────────────────────────────────────────── -->
      {% for section_pair in cv.sections %}
        {% assign section_title = section_pair[0] %}
        {% assign section_entries = section_pair[1] %}

        <div class="rcv-section">
          <a class="anchor" id="{{ section_title | slugify }}"></a>
          <div class="rcv-section-title"><b>{{ section_title }}</b></div>

          <!-- Experience & Teaching -->
          {% if section_title == 'Experience' or section_title == 'Teaching' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% if entry.position and entry.company %}
                    <strong>{{ entry.position }}</strong>, <em>{{ entry.company }}</em>
                  {% elsif entry.position %}
                    <strong>{{ entry.position }}</strong>
                  {% elsif entry.company %}
                    <em>{{ entry.company }}</em>
                  {% endif %}
                  {% if entry.summary %}
                    <div>{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
                  {% endif %}
                  {% if entry.highlights %}
                    <ul class="rcv-highlights">
                      {% for h in entry.highlights %}
                        <li>{{ h | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
                <div class="rcv-entry-date">
                  {% if entry.start_date %}
                    {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                  {% elsif entry.end_date %}
                    {{ entry.end_date }}
                  {% endif %}
                </div>
              </div>
            {% endfor %}

          <!-- Education -->
          {% elsif section_title == 'Education' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% if entry.degree and entry.area and entry.institution %}
                    <strong>{{ entry.degree }} in {{ entry.area }}</strong>, <em>{{ entry.institution }}</em>
                  {% elsif entry.degree and entry.institution %}
                    <strong>{{ entry.degree }}</strong>, <em>{{ entry.institution }}</em>
                  {% elsif entry.institution %}
                    <em>{{ entry.institution }}</em>
                  {% endif %}
                  {% if entry.summary %}
                    <div>{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
                  {% endif %}
                  {% if entry.highlights %}
                    <ul class="rcv-highlights">
                      {% for h in entry.highlights %}
                        <li>{{ h | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
                <div class="rcv-entry-date">
                  {% if entry.start_date %}
                    {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                  {% elsif entry.end_date %}
                    {{ entry.end_date }}
                  {% endif %}
                </div>
              </div>
            {% endfor %}

          <!-- Publications & Preprints -->
          {% elsif section_title == 'Publications' or section_title == 'Publications & Preprints' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% assign authors_joined = entry.authors | join: ', ' %}
                  {{ authors_joined | markdownify | remove: '<p>' | remove: '</p>' }}
                  ({{ entry.date }}).
                  {{ entry.title | markdownify | remove: '<p>' | remove: '</p>' }}.
                  {% if entry.journal %}<em>{{ entry.journal }}</em>.{% endif %}
                </div>
              </div>
            {% endfor %}

          <!-- Invited Talks -->
          {% elsif section_title == 'Invited talks' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% if entry.position %}<strong>{{ entry.position }}</strong>{% endif %}
                  {% if entry.company %}, <em>{{ entry.company }}</em>{% endif %}
                </div>
                <div class="rcv-entry-date">{{ entry.date }}</div>
              </div>
            {% endfor %}

          <!-- Funding -->
          {% elsif section_title == 'Funding' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% if entry.name %}<strong>{{ entry.name }}</strong>{% endif %}
                  {% if entry.summary %}
                    <div style="font-style:italic; font-size:0.9rem">
                      {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
                    </div>
                  {% endif %}
                </div>
                <div class="rcv-entry-date">
                  {% if entry.start_date %}
                    {{ entry.start_date }}{% if entry.end_date %} – {{ entry.end_date }}{% else %} – present{% endif %}
                  {% elsif entry.end_date %}
                    {{ entry.end_date }}
                  {% endif %}
                </div>
              </div>
            {% endfor %}

          <!-- Reviewing -->
          {% elsif section_title == 'Reviewing' %}
            <div class="rcv-plain">
              {% if section_entries.first %}
                {{ section_entries.first | markdownify | remove: '<p>' | remove: '</p>' }}
              {% else %}
                {{ section_entries | markdownify | remove: '<p>' | remove: '</p>' }}
              {% endif %}
            </div>

          <!-- Outreach and service -->
          {% elsif section_title == 'Outreach and service' %}
            {% for entry in section_entries %}
              <div class="rcv-entry">
                <div class="rcv-entry-main">
                  {% if entry.name %}<strong>{{ entry.name }}</strong>{% endif %}
                  {% if entry.summary %}
                    <div style="font-style:italic; font-size:0.9rem">
                      {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
                    </div>
                  {% endif %}
                </div>
                <div class="rcv-entry-date">
                  {% capture date_display %}
                    {% if entry.start_date %}
                      {{ entry.start_date }} – {% if entry.end_date %}{{ entry.end_date }}{% else %}present{% endif %}
                    {% elsif entry.date %}
                      {{ entry.date }}
                    {% endif %}
                  {% endcapture %}
                  {{ date_display | strip }}
                </div>
              </div>
            {% endfor %}

          <!-- al-folio native section fallbacks -->
          {% elsif section_title == 'Awards' or section_title == 'Honors and Awards' %}
            {% assign entries = section_entries %}{% include cv/awards.liquid %}
          {% elsif section_title == 'Skills' %}
            {% assign entries = section_entries %}{% include cv/skills.liquid %}
          {% elsif section_title == 'Languages' %}
            {% assign entries = section_entries %}{% include cv/languages.liquid %}
          {% elsif section_title == 'Interests' or section_title == 'Academic Interests' %}
            {% assign entries = section_entries %}{% include cv/interests.liquid %}
          {% elsif section_title == 'Certificates' %}
            {% assign entries = section_entries %}{% include cv/certificates.liquid %}
          {% elsif section_title == 'Projects' or section_title == 'Open Source Projects' %}
            {% assign entries = section_entries %}{% include cv/projects.liquid %}
          {% elsif section_title == 'References' %}
            {% assign entries = section_entries %}{% include cv/references.liquid %}

          <!-- Generic fallback -->
          {% else %}
            {% for entry in section_entries %}
              {% if entry.bullet %}
                <div class="rcv-plain">• {{ entry.bullet | markdownify | remove: '<p>' | remove: '</p>' }}</div>
              {% elsif entry.label %}
                <div class="rcv-plain"><strong>{{ entry.label }}:</strong> {{ entry.details }}</div>
              {% endif %}
            {% endfor %}
          {% endif %}

        </div><!-- /rcv-section -->
      {% endfor %}

    </div><!-- /rcv-wrap -->
  </article>
</div>
