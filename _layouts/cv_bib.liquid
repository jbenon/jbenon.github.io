<div class="rcv-entry">
  <div class="rcv-entry-main">
    {% assign authors = entry.author | split: " and " %}
    {% assign formatted = "" %}
    {%- for author in authors -%}
      {%- assign parts = author | strip | split: ", " -%}
      {%- if parts.size == 2 -%}
        {%- capture one %}{{ parts[1] | strip | split: " " | last }} {{ parts[0] }}{%- endcapture -%}
      {%- else -%}
        {%- capture one %}{{ author | strip }}{%- endcapture -%}
      {%- endif -%}
      {%- assign author_clean = author | strip -%}
      {%- unless forloop.first %}{% if forloop.last %}, and {% else %}, {% endif %}{% endunless -%}
      {%- if author_clean contains "Bénon" or author_clean contains "Benon" %}<strong>{{ one | strip }}</strong>{%- else %}{{ one | strip }}{%- endif -%}
    {%- endfor %}
    ({{ entry.year }}).
    {% if entry.url %}<a href="{{ entry.url }}" target="_blank">{{ entry.title }}</a>{% else %}{{ entry.title }}{% endif %}.
    {% if entry.journal %}<em>{{ entry.journal }}</em>.{% elsif entry.booktitle %}<em>{{ entry.booktitle }}</em>.{% endif %}
  </div>
</div>